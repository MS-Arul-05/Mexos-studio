# ─────────────────────────────────────────────────────────────────────────────
# Mexos Studio API — PRODUCTION environment (AWS free-tier stack, ap-south-1)
#
# Topology this file is written for:
#   Netlify frontend (https://mexos.netlify.app)
#     → CloudFront (terminates HTTPS, redirect-to-https)
#       → EC2 t3.micro (Ubuntu 24.04, 1GB RAM + 2GB swap):
#           nginx :80 → api :4000 (image pulled from ECR) + redis
#   Database = AWS RDS PostgreSQL 16 db.t4g.micro  (NO postgres container)
#   Uploads  = AWS S3 bucket in ap-south-1
#
# HOW TO USE
#   1. Copy this file to the EC2 box as /opt/mexos/.env (ec2-user-data.sh
#      creates /opt/mexos, and /opt/mexos/deploy.sh refuses to run without it).
#      From the repo root in Git Bash:
#        scp -i ~/mexos-key.pem deploy/aws/env.production.aws.example ubuntu@<EC2_PUBLIC_IP>:/opt/mexos/.env
#   2. On the box, replace every CHANGE_ME value:   nano /opt/mexos/.env
#   3. Lock it down (it holds secrets):             chmod 600 /opt/mexos/.env
#   4. Confirm nothing was missed — this must print NOTHING:
#        grep CHANGE_ME /opt/mexos/.env
#   5. NEVER commit a filled-in copy of this file to git.
#
# GENERATING SECRETS — run this on any machine with Node installed (Git Bash
# or PowerShell on Windows both work). Run it once PER secret; every secret
# must be a DIFFERENT value:
#
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# THE API REFUSES TO BOOT in production (src/config/production-check.ts) unless:
#   - JWT_ACCESS_SECRET / JWT_REFRESH_SECRET / JWT_GUEST_SECRET are each
#     32+ chars AND all three are different values
#   - ADMIN_API_KEY is 32+ chars
#   - CORS_ORIGINS is set (the API never allows all origins in production)
#   - DATABASE_URL is set
#   - If PAYMENT_GATEWAY_KEY_ID is set, PAYMENT_GATEWAY_KEY_SECRET and
#     PAYMENT_WEBHOOK_SECRET must be set too
#   - If WHATSAPP_PROVIDER=meta, WHATSAPP_API_TOKEN, WHATSAPP_VERIFY_TOKEN
#     and WHATSAPP_APP_SECRET must all be set
# Any CHANGE_ME left below fails those checks on purpose — the api container
# will restart-loop until you fix it (check: docker compose logs api).
#
# FORMAT RULES — this exact file is read by THREE parsers: docker compose
# variable interpolation (${API_IMAGE}), compose `env_file:`, and
# `docker run --env-file` (the migration step). The docker-run parser is very
# literal, so:
#   - no quotes around values
#   - no comments on the same line as a value (own-line comments only)
#   - no spaces around =
# ─────────────────────────────────────────────────────────────────────────────

# ── Deploy: ECR image used by docker-compose.aws.yml ────────────────────────
# docker compose automatically reads this .env and substitutes ${API_IMAGE}.
# deploy.sh reads the same value for the per-deploy migration step:
#   docker run --rm --env-file .env <this-image> npx prisma migrate deploy
# Find your 12-digit AWS account id:
#   aws sts get-caller-identity --region ap-south-1 --query Account --output text
# Format: <account-id>.dkr.ecr.ap-south-1.amazonaws.com/<repo>:<tag>
API_IMAGE=CHANGE_ME_ACCOUNT_ID.dkr.ecr.ap-south-1.amazonaws.com/mexos-api:latest

# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
# nginx (:80) proxies to the api container on this port. Leave as 4000 — the
# Dockerfile EXPOSEs it and the nginx config targets it.
PORT=4000
LOG_LEVEL=info

# ── Hardening ────────────────────────────────────────────────────────────────
# Exact origin(s) allowed to call this API from a browser. Comma-separated,
# no trailing slashes. Add your custom domain here later when you buy one.
CORS_ORIGINS=https://mexos.netlify.app

# true — this API sits behind nginx + CloudFront, so trust X-Forwarded-*
# headers (required for correct client IPs in rate limiting).
TRUST_PROXY=true

# MUST STAY EMPTY — do NOT write the word "false" here. This flag is coerced
# with Boolean(), so the non-empty string "false" would turn it ON. Empty = off.
# It must be OFF because CloudFront terminates TLS and talks to this box over
# plain HTTP :80 — an in-app http→https redirect would loop forever. Visitors
# still always get HTTPS: CloudFront's viewer-protocol-policy is
# redirect-to-https, so the browser-facing side is encrypted end to end.
ENFORCE_HTTPS=

# Baseline per-IP abuse guard: RATE_LIMIT_MAX requests per
# RATE_LIMIT_WINDOW_MIN minutes across /api (shared across restarts via Redis).
RATE_LIMIT_WINDOW_MIN=15
RATE_LIMIT_MAX=300

# Requests running longer than this fail securely with 503 (DoS guard).
REQUEST_TIMEOUT_MS=30000

# ── Database — AWS RDS PostgreSQL 16 (db.t4g.micro, ap-south-1) ─────────────
# There is NO postgres container on this box; the API connects to RDS directly.
# Replace CHANGE_ME_RDS_ENDPOINT with the FULL endpoint from: RDS Console →
# Databases → your DB → Connectivity & security → Endpoint. It looks like:
#   mexos-db.abc123xyz456.ap-south-1.rds.amazonaws.com
# The /tshirt database must exist: when creating the RDS instance, set
# "Initial database name" to tshirt (it is NOT created automatically otherwise).
# Keep the query string EXACTLY: ?schema=public&sslmode=require
#   - schema=public   → required by Prisma
#   - sslmode=require → RDS connections must use TLS
# Password tip: generate it with the node one-liner above — hex characters are
# URL-safe. If you choose your own password, it must NOT contain characters
# like @ : / ? # unless you URL-encode them.
DATABASE_URL=postgresql://postgres:CHANGE_ME_DB_PASSWORD@CHANGE_ME_RDS_ENDPOINT:5432/tshirt?schema=public&sslmode=require

# ── Redis (container on this box) ────────────────────────────────────────────
# Shared rate limits + BullMQ notification queue (retry + dead-letter).
# "redis" is the compose service name; it is reachable ONLY on the private
# Docker network (no host port published), so no password is needed here.
# If you later move to a managed Redis, use: rediss://:PASSWORD@host:port
# Redis being down degrades gracefully (in-memory limits, inline sends) — it
# never takes the API down.
REDIS_URL=redis://redis:6379

# ── Auth / JWT ───────────────────────────────────────────────────────────────
# THREE DISTINCT secrets — run the node one-liner three separate times and
# paste a different value for each. Boot fails if any is under 32 chars or if
# any two are identical.
JWT_ACCESS_SECRET=CHANGE_ME_1
JWT_REFRESH_SECRET=CHANGE_ME_2
JWT_GUEST_SECRET=CHANGE_ME_3
# Token lifetimes — the defaults below are production-appropriate.
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
JWT_GUEST_TTL=7d

# ── Checkout shipping rule (server-authoritative, INR) ──────────────────────
# Flat SHIPPING_FEE on orders below FREE_SHIPPING_THRESHOLD; free at/above it.
# The client-displayed fee is never trusted — these values are the truth.
SHIPPING_FEE=79
FREE_SHIPPING_THRESHOLD=999

# ── OTP (login codes) ────────────────────────────────────────────────────────
OTP_TTL_MINUTES=10
OTP_MAX_PER_HOUR=3

# ── OTP delivery — console | whatsapp (Meta Cloud API) ──────────────────────
# console = OTPs are only written to the API logs (view them with:
#   docker compose logs -f api).
# The API boots with console but logs a warning — REAL CUSTOMERS CANNOT LOG IN
# until you switch to whatsapp. WhatsApp is the only production channel (SMS
# dropped per client decision 2026-07-09). OTP_PROVIDER=whatsapp requires
# WHATSAPP_API_TOKEN + WHATSAPP_PHONE_NUMBER_ID (below) at boot, plus an
# approved AUTHENTICATION-category template named in WHATSAPP_OTP_TEMPLATE.
OTP_PROVIDER=console
WHATSAPP_OTP_TEMPLATE=otp_login
WHATSAPP_OTP_LANGUAGE=en

# ── WhatsApp notifications — noop | meta | twilio | gupshup ─────────────────
# noop = order status updates / invoices are skipped (safe default until the
# WhatsApp Business API is approved). If you switch to meta, then
# WHATSAPP_API_TOKEN, WHATSAPP_VERIFY_TOKEN and WHATSAPP_APP_SECRET all become
# REQUIRED at boot (inbound webhooks must be verifiable).
WHATSAPP_PROVIDER=noop
WHATSAPP_BUSINESS_NUMBER=+910000000000
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_STATUS_TEMPLATE=order_status_update
WHATSAPP_GRAPH_VERSION=v21.0

# ── Payments — razorpay | payu | stripe ──────────────────────────────────────
# Empty keys = stub gateway (the API boots and logs a warning; no real money
# moves). When you add live Razorpay keys, ALL THREE values below must be set
# or the API refuses to boot (webhooks would be unverifiable otherwise).
# Razorpay dashboard → Account & Settings → API Keys / Webhooks. Point the
# webhook URL at: https://<your-cloudfront-domain>/api/v1/payments/webhook
PAYMENT_GATEWAY=razorpay
PAYMENT_GATEWAY_KEY_ID=
PAYMENT_GATEWAY_KEY_SECRET=
PAYMENT_WEBHOOK_SECRET=

# ── Upload virus scanning — noop | clamav ────────────────────────────────────
# Keep noop on this box: clamav needs ~1GB+ RAM and the t3.micro only has 1GB.
# (A real scanner that errors REJECTS files — noop accepts them unscanned.)
VIRUS_SCAN_PROVIDER=noop

# ── S3 — custom design uploads (bucket in ap-south-1) ────────────────────────
# IMPORTANT: leave S3_ENDPOINT EMPTY for real AWS S3 — the SDK then uses the
# regional AWS endpoint (https://<bucket>.s3.ap-south-1.amazonaws.com)
# automatically. Only set S3_ENDPOINT for S3-compatible clones (R2, MinIO).
S3_ENDPOINT=
S3_REGION=ap-south-1
# Your bucket name (globally unique, e.g. mexos-design-uploads-<something>).
# If S3_BUCKET / S3_ACCESS_KEY / S3_SECRET_KEY are not ALL set, the API
# silently falls back to a stub provider and uploads never reach S3.
S3_BUCKET=CHANGE_ME_BUCKET_NAME
# Access keys of the DEDICATED IAM user that can only touch this bucket
# (created in the deploy guide) — never your root/admin AWS keys.
S3_ACCESS_KEY=CHANGE_ME_IAM_ACCESS_KEY_ID
S3_SECRET_KEY=CHANGE_ME_IAM_SECRET_ACCESS_KEY

# ── Meta Ads (Conversions API) — optional ────────────────────────────────────
# Empty = server-side conversion events are a no-op (warning only, safe).
META_PIXEL_ID=
META_CONVERSIONS_API_TOKEN=

# ── Admin API ────────────────────────────────────────────────────────────────
# Key guarding the internal /api/v1/admin endpoints. 32+ chars REQUIRED at
# boot — use the node one-liner. ADMIN_API_KEYS (optional) supersedes the
# single key with per-admin labeled keys for audit + rotation, formatted as:
#   label:key,label2:key2
ADMIN_API_KEY=CHANGE_ME_4
ADMIN_API_KEYS=

# ── Observability — optional ─────────────────────────────────────────────────
# Empty METRICS_TOKEN → GET /metrics answers only to loopback on the box.
# Set a 32+ char token to allow remote Prometheus scraping with
# "Authorization: Bearer <token>".
METRICS_TOKEN=

# OpenTelemetry tracing — leave disabled (no collector runs on this free-tier
# box, and the SDK costs RAM we don't have). Enable ONLY with OTEL_ENABLED=true
# plus a reachable OTLP collector endpoint.
OTEL_ENABLED=false
OTEL_SERVICE_NAME=tshirt-api
OTEL_EXPORTER_OTLP_ENDPOINT=
