# ─────────────────────────────────────────────────────────────
# Custom T-Shirt Brand Backend — environment variables
# Copy to .env and fill in real values. NEVER commit .env.
# ─────────────────────────────────────────────────────────────

# Core
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Hardening (set appropriately in production)
# Comma-separated allowed origins; leave unset in dev to allow all.
CORS_ORIGINS=
TRUST_PROXY=false          # true when running behind a load balancer / reverse proxy
ENFORCE_HTTPS=false        # true in production to redirect http→https (behind proxy)
RATE_LIMIT_WINDOW_MIN=15
RATE_LIMIT_MAX=300
REQUEST_TIMEOUT_MS=30000

# Database (Postgres) — matches docker-compose.yml defaults.
# DB_HOST_PORT is the host port mapped to the container's 5432 (kept off the
# default 5432 to avoid clashing with other local Postgres instances).
DB_HOST_PORT=5544
DATABASE_URL=postgresql://postgres:postgres@localhost:5544/tshirt?schema=public

# Auth / JWT — use DISTINCT, 32+ char random secrets per audience.
# Generate each: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_GUEST_SECRET=change-me-guest-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
JWT_GUEST_TTL=7d

# OTP
OTP_TTL_MINUTES=10
OTP_MAX_PER_HOUR=3

# SMS / OTP provider — console (dev) | msg91 | twilio
# console = logs OTP (no external calls). Set to msg91 or twilio for real OTPs.
SMS_PROVIDER=console
# MSG91 (recommended, India): authkey + a DLT flow template with an OTP variable.
SMS_PROVIDER_API_KEY=
SMS_TEMPLATE_ID=
# The OTP variable's name in your DLT template, case-sensitive: the text between
# the ## markers. Template "...code is ##OTP##..." → OTP. Defaults to OTP.
SMS_TEMPLATE_VAR=OTP
# Twilio (alternative)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# WhatsApp — TODO: confirm with client (Meta Cloud API vs BSP)
# Default notification provider is "noop" until Business API is approved.
WHATSAPP_PROVIDER=noop
WHATSAPP_BUSINESS_NUMBER=+910000000000
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_STATUS_TEMPLATE=order_status_update
WHATSAPP_GRAPH_VERSION=v21.0

# Payment gateway — TODO: confirm with client (Razorpay default)
PAYMENT_GATEWAY=razorpay
PAYMENT_GATEWAY_KEY_ID=
PAYMENT_GATEWAY_KEY_SECRET=
PAYMENT_WEBHOOK_SECRET=

# Virus scan for uploaded design files — noop (accept all) | clamav (planned).
# Runs when a file is attached to a custom order; a failing scanner REJECTS files.
VIRUS_SCAN_PROVIDER=noop

# S3-compatible storage (custom design uploads)
S3_ENDPOINT=
S3_REGION=ap-south-1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Meta Ads (Conversions API)
META_PIXEL_ID=
META_CONVERSIONS_API_TOKEN=

# Admin API (internal admin endpoints). Use a 32+ char random key.
# ADMIN_API_KEY = single-key fallback. ADMIN_API_KEYS = per-admin attribution +
# rotation as "label:key,label2:key2" (each request is audited by label).
ADMIN_API_KEY=change-me-admin-key
ADMIN_API_KEYS=

# Redis — shared rate limits across instances + BullMQ notification queue
# (retry + dead-letter). Unset = in-memory limits + inline notification sends
# (single-instance dev mode). REQUIRED before running multiple api replicas.
# docker-compose.prod.yml provisions this as redis://redis:6379.
# Managed/external Redis: use rediss://:PASSWORD@host:port for TLS + auth.
# Redis being DOWN degrades gracefully (in-memory limits, inline notifications) —
# it never takes the API down.
REDIS_URL=

# Optional: bearer token to guard GET /metrics for remote Prometheus scraping.
# Unset → /metrics is served only to loopback (127.0.0.1).
METRICS_TOKEN=

# Optional: OpenTelemetry distributed tracing. Set OTEL_ENABLED=true and point
# OTEL_EXPORTER_OTLP_ENDPOINT at a collector (e.g. http://otel-collector:4318).
OTEL_ENABLED=false
OTEL_SERVICE_NAME=tshirt-api
OTEL_EXPORTER_OTLP_ENDPOINT=
